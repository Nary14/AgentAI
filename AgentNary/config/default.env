# AgentNary Configuration
# Copy this to custom.env and modify

# Default model to load
DEFAULT_MODEL=cybersec-agent

# Browser settings
BROWSER=firefox
HEADLESS=false

# Paths
DOWNLOAD_DIR=$HOME/sgoinfre/AgentNary/downloads
SCRIPTS_DIR=$HOME/sgoinfre/AgentNary/scripts
NOTES_DIR=$HOME/sgoinfre/AgentNary/notes

# Ollama settings
OLLAMA_CONTEXT_LENGTH=16384
OLLAMA_TEMPERATURE=0.3

# Safety
ALLOW_RM=false
MAX_EXECUTION_TIME=120
